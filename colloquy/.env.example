# Required. Server-side only — never exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Claude model used for every phase. Defaults to claude-opus-4-8.
COLLOQUY_MODEL=claude-opus-4-8

# Optional. Maximum number of debate rounds after independent analysis. Default: 4.
COLLOQUY_MAX_ROUNDS=4

# Optional. Directory where run transcripts are written as JSON. Default: ./runs
# Point this at a NAS mount later without touching code.
COLLOQUY_RUNS_DIR=./runs
